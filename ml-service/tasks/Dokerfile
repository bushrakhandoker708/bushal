# ml-service/Dockerfile

#This file tells Railway.app or Render.com exactly how to build and run your Python microservice. It uses a lightweight Python base image, installs the necessary system dependencies for your math libraries (like scikit-learn and pandas), and starts the FastAPI server using uvicorn.


# 1. Use an official lightweight Python image
FROM python:3.11-slim

# 2. Set environment variables
# Prevents Python from writing pyc files to disk
ENV PYTHONDONTWRITEBYTECODE=1
# Prevents Python from buffering stdout and stderr
ENV PYTHONUNBUFFERED=1

# 3. Set the working directory in the container
WORKDIR /app

# 4. Install system dependencies
# build-essential is often needed for compiling C-extensions (e.g., for pandas, scikit-learn, psycopg2)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# 5. Copy the requirements file
COPY requirements.txt .

# 6. Install Python dependencies
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# 7. Copy the rest of the application code
COPY . .

# 8. Expose the port the app runs on
EXPOSE 8000

# 9. Define the command to run the application
# Using uvicorn to serve the FastAPI app
# --host 0.0.0.0 makes it accessible from outside the container
# --port 8000 matches the EXPOSE directive
# --workers 2 allows handling concurrent requests efficiently
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "2"]